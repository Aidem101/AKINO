AKINO_APP_ENV=local
AKINO_APP_ORIGIN=
AKINO_TRUST_PROXY=0
# Space- or comma-separated HTTPS origins for externally hosted images and video.
AKINO_CSP_IMAGE_ORIGINS=
AKINO_CSP_MEDIA_ORIGINS=

AKINO_DB_HOST=mysql-8.0
AKINO_DB_PORT=3306
AKINO_DB_DATABASE=akino_app
AKINO_DB_USERNAME=root
AKINO_DB_PASSWORD=
AKINO_DATABASE_URL=
AKINO_DB_CHARSET=utf8mb4
AKINO_DB_TIMEOUT=1
AKINO_DB_FALLBACK_HOSTS=
AKINO_DB_SSL_CA=
AKINO_DB_SSL_VERIFY_SERVER_CERT=1

AKINO_ADMIN_LOGIN=akino_admin
AKINO_ADMIN_PASSWORD=replace-with-a-strong-password
AKINO_ADMIN_DISPLAY_NAME=Akino admin
AKINO_ADMIN_AVATAR_PATH=img/people/image_2025-11-10_00-02-43.png

# Generate a unique random value with at least 32 characters for every environment.
AKINO_AUTH_SECRET=
# Use a separate random value in production to encrypt database backups.
AKINO_BACKUP_SECRET=

# Demo/local flags. Demo codes are ignored when AKINO_APP_ENV=production.
AKINO_DEMO_AUTH=1
AKINO_RUNTIME_BOOTSTRAP=0
